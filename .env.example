# Win Journal configuration — template.
# Copy this file to ".env" and fill in your values:   cp .env.example .env
# The real .env is git-ignored so your secrets are never committed.
#
# NOTE: this app uses a minimal built-in .env reader that does NOT strip inline
# "# ..." comments. Keep comments on their own lines and put ONLY the value after
# each "=" (otherwise the comment becomes part of the value).

# ---- Anthropic API (optional AI features) -------------------------------------
# Anthropic API key for optional AI summaries, resume bullets, and bullet
# suggestions. Leave blank to run fully offline. Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional overrides (uncomment to change):
# ANTHROPIC_MODEL=claude-opus-4-8
# PORT=4321

# ---- Entries database (PostgreSQL) --------------------------------------------
# Points at the always-present default "postgres" database so NO database needs
# to be created first. The app auto-creates its "entries" table there on first boot.
# (Switch DATABASE_NAME to win_journal once you've run `createdb win_journal`.)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
# CHANGE to your local Postgres password:
DATABASE_PASSWORD=
# Use false for local Postgres; set true for hosted DBs (Neon, Vercel, etc.).
DATABASE_SSL=false
# Optional: path to a CA PEM file, only for hosted DBs that need a custom CA.
# Leave unset for Neon/Vercel (their certs are publicly trusted). Never disable
# certificate verification.
# DATABASE_CA_CERT=
