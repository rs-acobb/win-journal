# Win Journal configuration — template.
# Copy this file to ".env" and fill in your values:   cp .env.example .env
# The real .env is git-ignored so your key is never committed.

# Anthropic API key for optional AI summaries, resume bullets, and bullet suggestions.
# Leave blank to run fully offline. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional overrides (uncomment to change):
# ANTHROPIC_MODEL=claude-opus-4-8
# PORT=4321
